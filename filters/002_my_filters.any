/allow-servlet-access {
	/type "allow"
	/method '(POST|GET)'
	/path "/bin/mycode/*"
	/url "/bin/mycode/*"
	/extension '(json|xml|jsp)'
}
/allow-html-from-content {
	/type "allow"
	/method "GET"
	/path "/content/good/*"
	/url '/content/good/.*\.html'
	/extension "html"
}
/allow-images-from-dam {
	/type "allow"
	/method "GET"
	/path "/content/dam/*"
	/url '/content/dam/log\.(jpg|jpeg|gif|png)'
	/extension '(jpg|jpeg|gif|png)'
}
